from itertools import combinations

def subset_sum(S, T):
    n = len(S)

    for r in range(1, n + 1):
        for subconjunto in combinations(S, r):
            if sum(subconjunto) == T:
                return True, subconjunto

    return False, None


# Caso 1 - Pequeno
S1 = [2, 4, 6, 10]
T1 = 16

# Caso 2 - Médio
S2 = [-5, -2, 1, 3, 7, 12, 15, 21]
T2 = 0

print(subset_sum(S1, T1))
print(subset_sum(S2, T2))
