# TESTE DO SISTEMA
# ------------------------------


fila = MaxHeap()


pacientes = [
    ("João", 7),
    ("Maria", 10),
    ("Carlos", 5),
    ("Ana", 8)
]


for nome, dor in pacientes:
    fila.inserir(nome, dor)


print("Fila:")
print(fila.heap)


print("\nPaciente atendido:")
print(fila.atender())


print("\nDepois do atendimento:")
print(fila.heap)


# aumenta prioridade de um paciente
fila.alterar_prioridade(1, 9)


print("\nApós alterar prioridade:")
print(fila.heap)
