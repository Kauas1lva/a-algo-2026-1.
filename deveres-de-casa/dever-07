class MaxHeap:
    
    def __init__(self):
        self.heap = []


    # adiciona paciente na fila
    def inserir(self, paciente, dor):
        self.heap.append((paciente, dor))
        self.subir(len(self.heap)-1)


    # reorganiza para cima
    def subir(self, indice):

        pai = (indice - 1) // 2

        while indice > 0 and self.heap[indice][1] > self.heap[pai][1]:

            self.heap[indice], self.heap[pai] = (
                self.heap[pai],
                self.heap[indice]
            )

            indice = pai
            pai = (indice - 1) // 2



    # remove paciente mais urgente
    def atender(self):

        if len(self.heap) == 0:
            return None


        maior = self.heap[0]

        self.heap[0] = self.heap[-1]

        self.heap.pop()

        self.descer(0)

        return maior



    # reorganiza para baixo
    def descer(self, indice):

        tamanho = len(self.heap)

        while True:

            maior = indice

            esquerda = 2 * indice + 1
            direita = 2 * indice + 2


            if esquerda < tamanho and self.heap[esquerda][1] > self.heap[maior][1]:
                maior = esquerda


            if direita < tamanho and self.heap[direita][1] > self.heap[maior][1]:
                maior = direita


            if maior == indice:
                break


            self.heap[indice], self.heap[maior] = (
                self.heap[maior],
                self.heap[indice]
            )

            indice = maior



    # altera prioridade do paciente
    def alterar_prioridade(self, indice, nova_dor):

        dor_antiga = self.heap[indice][1]

        paciente = self.heap[indice][0]

        self.heap[indice] = (paciente, nova_dor)


        # aumentou a dor
        if nova_dor > dor_antiga:
            self.subir(indice)


        # diminuiu a dor
        else:
            self.descer(indice)



